-- MAIN AUTOFARM LOOP
-- ============================================

local AutofarmRunning = false

local function MainAutofarmController()
    if AutofarmRunning then return end
    AutofarmRunning = true
    
    -- Spawn bike first
    if not SpawnAndSitOnBike() then
        Configuration.Status = "[ERROR] Failed to spawn bike!"
        AutofarmRunning = false
        return
    end

    while Configuration.Autofarming do
        WaitForReady()
        
        local ApartmentOk = StartMarshmallowFarm()
        if not ApartmentOk then 
            task.wait(5) 
            continue 
        end
        
        PurchaseMarshmallowIngredients()
        
        local WaterOk = PourWater()
        if not WaterOk then
            repeat 
                StartMarshmallowFarm() 
                WaterOk = PourWater() 
            until WaterOk
        end
        
        PurchasePotatoIngredients()
        MakePotatoChips()
        
        AddSugarAndGelatin()
        BagMarshmallowAndSell()
        
        Configuration.Status = "[CYCLE] Complete! Restarting..."
        task.wait(2)
    end
    
    AutofarmRunning = false
end

