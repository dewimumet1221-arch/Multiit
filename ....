-- ============================================

local function DoRejoin()
    if not Configuration.AutoRejoiner then return end
    Configuration.Autofarming = false
    Configuration.TimesRejoined = Configuration.TimesRejoined + 1
    task.wait(2)
    TeleportService:Teleport(10179538382)
end

local function SetupAntiDeath(char)
    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end
    
    hum.HealthChanged:Connect(function(hp)
        if not Configuration.AutoAntiDeath then return end
        if hp > 0 and hp < 95 then
            Configuration.Status = "[ANTI-DEATH] Taking damage, teleporting!"
            DirtBikeTeleport(Locations.Healing)
        end
    end)
end
