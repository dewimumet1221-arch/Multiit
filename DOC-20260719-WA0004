    local startTime = os.clock()
    local startCash = GetCurrentCashAmount()
    
    while task.wait(1) do
        Configuration.Runtime = math.floor(os.clock() - startTime)
        Configuration.CashMade = GetCurrentCashAmount() - startCash
    end
end)

-- Stuck detection
task.spawn(function()
    local lastCash = 0
    local lastChange = os.clock()
    
    task.wait(60)
    lastCash = GetCurrentCashAmount()
    
    while task.wait(30) do
        if not Configuration.Autofarming then
            lastCash = GetCurrentCashAmount()
            lastChange = os.clock()
            continue
        end
        
        local currentCash = GetCurrentCashAmount()
        if currentCash ~= lastCash then
            lastCash = currentCash
            lastChange = os.clock()
        end
        
        if os.clock() - lastChange >= 300 then
            Configuration.Status = "[STUCK] Rejoining..."
            DoRejoin()
            return
        end
    end
end)

