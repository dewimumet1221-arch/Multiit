        Configuration.AutoRejoiner = v
    end)
    
    local togglePerf = CreateToggle("⚡ Performance Saver", "PerfSaver", false, function(v)
        Configuration.PerformanceSaver = v
        if setfpscap then setfpscap(v and 15 or 60) end
        game:GetService("RunService"):Set3dRenderingEnabled(not v)
    end)
    
    CreateSection("🎯 GOAL SETTINGS")
    
    local toggleGoal = CreateToggle("▶ Goal Enabled", "GoalEnabled", false, function(v)
        Configuration.GoalEnabled = v
    end)
    
    CreateSection("📊 STATISTICS")
    
    local statusLabel = CreateLabel("📌 Status: Idle", Color3.fromRGB(100, 200, 255))
    local runtimeLabel = CreateLabel("⏰ Runtime: 00:00:00")
    local cashLabel = CreateLabel("💰 Cash: $0")
    local chipsLabel = CreateLabel("🍟 Chips Fed: 0")
    local cardsLabel = CreateLabel("💳 Cards Swiped: 0")
    local marshLabel = CreateLabel("🧂 Marshmallows: 0")
    local rejoinLabel = CreateLabel("🔄 Rejoined: 0")
    
