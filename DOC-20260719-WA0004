        if fakeID then EquipTool(fakeID) end
        task.wait(0.3)
        pcall(function() prompt:Fire() end)
        task.wait(0.5)
        UnequipTools()
    end
    
    -- Wait and claim card
    Configuration.Status = "[CARDS] Waiting 35s..."
    task.wait(35)
    
    local cardPickup = Workspace:FindFirstChild("CardPickup")
    if cardPickup then
        local prompt = cardPickup.Attachment.ProximityPrompt
        TeleportTo(cardPickup.Position)
        task.wait(0.3)
        pcall(function() prompt:Fire() end)
        task.wait(0.5)
    end
    
    -- Use card at ATM
    Configuration.Status = "[CARDS] Using ATM..."
    local atms = Workspace.Map.ATMS
    for _, atm in pairs(atms:GetChildren()) do
        if atm:FindFirstChild("ATMScreen") and atm.ATMScreen.Transparency == 0 then
            local prompt = atm.Attachment.ProximityPrompt
            TeleportTo(atm.Position)
            task.wait(0.3)
            pcall(function() prompt:Fire() end)
            task.wait(1)
            
            local atmUI = PlayerGui:FindFirstChild("ATM")
            if atmUI then
                local swipe = atmUI.Frame.Swipe
                if swipe then
                    pcall(function()
                        swipe:Fire()
                    end)
                    Configuration.CardsSwiped = Configuration.CardsSwiped + 1
                end
            end
            break
        end
    end
end

-- MAIN AUTOFARM LOOP
local autofarmRunning = false
local function MainAutofarm()
    if autofarmRunning then return end
    autofarmRunning = true
    
    while Configuration.Autofarming do
        WaitForReady()
        
        -- Step 1: Get apartment
        local aptOk = StartMarshmallowFarm()
        if not aptOk then
            task.wait(5)
            continue
        end
        
        -- Step 2: Make marshmallow
        PourWater()
        AddSugarAndGelatin()
        SellMarshmallow()
        
        -- Step 3: Make potato chips
        MakePotatoChips()
        
        -- Step 4: Credit card scam
        CreditCardScam()
        
        Configuration.Status = "[CYCLE] Complete! Restarting..."
        task.wait(2)
    end
    
    autofarmRunning = false
end

