            marshLabel.Text = "🧂 Marshmallows: " .. Configuration.MarshmallowsSold
            rejoinLabel.Text = "🔄 Rejoined: " .. Configuration.TimesRejoined
        end
    end)
    
    return {
        ToggleFarm = toggleFarm,
        ToggleAntiDeath = toggleAntiDeath,
        ToggleRejoiner = toggleRejoiner,
    }
