local function FindAvailableApartments()
    local Available = {}
    local Apartments = { "WH1", "BH3", "BH2", "BH4", "BH1", "LT1" }
    local CasinoApartments = { "Home 1", "Home 2", "Home 3", "Home 4" }
    
    for _, obj in next, Workspace:WaitForChild("Map").APTS:GetChildren() do
        if obj:IsA("Model") then
            local board = obj:FindFirstChild("Board", true)
            if board then
                local text = board.name.SurfaceGui.TextLabel.Text
                if text == "VACANT" or text == Player.Name then
                    table.insert(Available, obj)
                end
            end
        end
    end
    return Available
end

local function GetApartment()
    local apts = FindAvailableApartments()
    if #apts == 0 then return nil end
    return apts[Random:NextInteger(1, #apts)]
end

