local function MakePotatoChips()
    WaitForReady()
    Configuration.Status = "[POTATO] Starting..."
    
    -- Buy ingredients
    local storeRemote = ReplicatedStorage:WaitForChild("RemoteEvents"):WaitForChild("StorePurchase")
    TeleportTo(Locations.BuyPotato)
    task.wait(0.5)
    storeRemote:FireServer("Flour")
    task.wait(0.3)
    storeRemote:FireServer("Potato")
    task.wait(0.3)
    
    -- Claim task
    Configuration.Status = "[POTATO] Claiming task..."
    local clipboard = Workspace.Map.Locations["The Laboratory"].Prompts.Clipboard
    local prompt = clipboard.ProximityPrompt
    TeleportTo(Locations.Clipboard)
    task.wait(0.3)
    pcall(function() prompt:Fire() end)
    task.wait(0.5)
    
    -- Cut potato
    Configuration.Status = "[POTATO] Cutting..."
    local cutter = Workspace.Map.Locations["The Laboratory"]["Cutting Boards"]["Potato Cutter"].Model.Union
    prompt = cutter.Attachment.ProximityPrompt
    TeleportTo(Locations.PotatoCutter)
    task.wait(0.3)
    local potato = Player:FindFirstChild("Backpack"):FindFirstChild("Potato")
    if potato then
        EquipTool(potato)
        task.wait(0.3)
        pcall(function() prompt:Fire() end)
        task.wait(0.3)
        UnequipTools()
    end
    
    -- Bag potato
    Configuration.Status = "[POTATO] Bagging..."
    local bag = Workspace.Map.Locations["The Laboratory"].Prompts["Plastic Bag"]
    prompt = bag.Attachment.ProximityPrompt
    TeleportTo(Locations.PlasticBagLab)
    task.wait(0.3)
    pcall(function() prompt:Fire() end)
    task.wait(0.5)
    
    -- Mix
    Configuration.Status = "[POTATO] Mixing..."
    local bowl = Workspace.Map.Locations["The Laboratory"].Bowls:FindFirstChildOfClass("UnionOperation")
    prompt = bowl.ProximityPrompt
    TeleportTo(Locations.FlourBowl)
    task.wait(0.3)
    local flour = Player:FindFirstChild("Backpack"):FindFirstChild("Flour")
    if flour then
        EquipTool(flour)
        task.wait(0.3)
        pcall(function() prompt:Fire() end)
        task.wait(0.3)
        UnequipTools()
    end
    
    -- Cook
    Configuration.Status = "[POTATO] Cooking..."
    local pots = Workspace.Map.Locations["The Laboratory"].Pots
    for _, pot in pairs(pots:GetChildren()) do
        if pot:IsA("UnionOperation") then
            prompt = pot.ProximityPrompt
            if prompt then
                TeleportTo(pot.Position)
                task.wait(0.3)
                pcall(function() prompt:Fire() end)
                task.wait(1)
                break
            end
        end
    end
    
    -- Wait for cooking
    Configuration.Status = "[POTATO] Waiting 120s..."
    task.wait(120)
    
    -- Convert to hot chips
    Configuration.Status = "[POTATO] Converting..."
    TeleportTo(Locations.HotChipsMan)
    task.wait(0.5)
    local poorGuy = Workspace.Folders.NPCs["Poor Guy"]
    if poorGuy then
        prompt = poorGuy.UpperTorso.ProximityPrompt
        local chips = Player:FindFirstChild("Backpack"):FindFirstChild("Potato Chips")
        if chips then
            EquipTool(chips)
            task.wait(0.3)
            pcall(function() prompt:Fire() end)
            task.wait(0.3)
            UnequipTools()
        end
    end
    
    -- Feed homeless
    Configuration.Status = "[POTATO] Feeding homeless..."
    local homelessList = Workspace.Folders.HomelessPeople
    for _, homeless in pairs(homelessList:GetChildren()) do
        local hotChips = Player:FindFirstChild("Backpack"):FindFirstChild("Hot Chips")
        if not hotChips then break end
        
        local torso = homeless:FindFirstChild("UpperTorso")
        if torso then
            prompt = torso.ProximityPrompt
            TeleportTo(torso.Position)
            task.wait(0.3)
            EquipTool(hotChips)
            task.wait(0.3)
            pcall(function() prompt:Fire() end)
            task.wait(0.3)
            UnequipTools()
            Configuration.ChipsFed = Configuration.ChipsFed + 1
        end
    end
    
    return true
end

