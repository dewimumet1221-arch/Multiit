local function SellMarshmallow()
    WaitForReady()
    Configuration.Status = "[MARSH] Waiting to cook (60s)..."
    task.wait(60)
    
    Configuration.Status = "[MARSH] Selling..."
    
    local lamont = nil
    local folders = Workspace:FindFirstChild("Folders")
    if folders then
        local npcs = folders:FindFirstChild("NPCs")
        if npcs then
            lamont = npcs:FindFirstChild("Lamont Bell")
        end
    end
    
    if not lamont then
        BikeTeleport(Locations.BuyMarsh)
        task.wait(1)
        folders = Workspace:FindFirstChild("Folders")
        if folders then
            local npcs = folders:FindFirstChild("NPCs")
            if npcs then
                lamont = npcs:FindFirstChild("Lamont Bell")
            end
        end
    end
    
    if not lamont then 
        Configuration.Status = "[ERROR] Lamont Bell not found!"
        return false 
    end
    
    local prompt = nil
    local torso = lamont:FindFirstChild("UpperTorso")
    if torso then
        prompt = torso:FindFirstChild("ProximityPrompt")
    end
    if not prompt then
        prompt = lamont:FindFirstChild("ProximityPrompt")
    end
    
    if not prompt then
        Configuration.Status = "[ERROR] Lamont prompt not found!"
        return false
    end
    
    local backpack = Player:FindFirstChild("Backpack")
    if backpack then
        local itemsToSell = {}
        for _, item in pairs(backpack:GetChildren()) do
            if tostring(item.Name):find("Marshmallow") then
                table.insert(itemsToSell, item)
            end
        end
        
        for _, item in pairs(itemsToSell) do
            BikeTeleport(Locations.BuyMarsh)
            task.wait(0.5)
            EquipTool(item)
            task.wait(0.3)
            FirePrompt(prompt)
            task.wait(0.5)
            UnequipTools()
            Configuration.MarshmallowsSold = Configuration.MarshmallowsSold + 1
            task.wait(0.2)
        end
    end
    
    return true
end

