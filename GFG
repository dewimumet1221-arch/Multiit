local function FindAvailableApartments()
    local Available = {}
    local ApartmentNames = { "WH1", "BH3", "BH2", "BH4", "BH1", "LT1", "Home 1", "Home 2", "Home 3", "Home 4" }
    
    local map = Workspace:FindFirstChild("Map")
    if not map then return Available end
    
    local apts = map:FindFirstChild("APTS")
    if not apts then return Available end
    
    for _, obj in pairs(apts:GetChildren()) do
        if obj:IsA("Model") then
            local board = obj:FindFirstChild("Board", true)
            if board then
                local nameSurface = board:FindFirstChild("name")
                if nameSurface then
                    local gui = nameSurface:FindFirstChild("SurfaceGui")
                    if gui then
                        local label = gui:FindFirstChild("TextLabel")
                        if label then
                            local text = label.Text
                            if text == "VACANT" or text == Player.Name then
                                table.insert(Available, obj)
                            end
                        end
                    end
                end
            end
        end
    end
    
    return Available
end

local function GetApartment()
    local apts = FindAvailableApartments()
    if #apts == 0 then 
        Configuration.Status = "[APT] No apartment available!"
        return nil 
    end
    return apts[Random:NextInteger(1, #apts)]
end

local function StartMarshmallowFarm()
    WaitForReady()
    Configuration.Status = "[APT] Finding apartment..."
    
    local apt = GetApartment()
    if not apt then
        Configuration.Status = "[APT] None available!"
        return false
    end
    
    Configuration.Apartment = apt
    Configuration.Status = "[APT] Secured: " .. tostring(apt)
    return true
end

