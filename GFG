-- ============================================

local function MakePotatoChips()
    WaitForReady()
    Configuration.Status = "[POTATO] Starting..."
    
    local store = ReplicatedStorage:WaitForChild("RemoteEvents"):WaitForChild("StorePurchase")
    
    BikeTeleport(Locations.BuyPotato)
    task.wait(1)
    store:FireServer("Flour")
    task.wait(0.5)
    store:FireServer("Potato")
    task.wait(0.5)
    
    local lab = Workspace:FindFirstChild("Map")
    if lab then
        lab = lab:FindFirstChild("Locations")
        if lab then
            lab = lab:FindFirstChild("The Laboratory")
        end
    end
    
    if not lab then
        Configuration.Status = "[ERROR] Laboratory not found!"
        return false
    end
    
    Configuration.Status = "[POTATO] Claiming task..."
    local prompts = lab:FindFirstChild("Prompts")
    if prompts then
        local clipboard = prompts:FindFirstChild("Clipboard")
        if clipboard then
            local prompt = clipboard:FindFirstChild("ProximityPrompt")
            if prompt then
                BikeTeleport(Locations.Clipboard)
                task.wait(0.5)
                FirePrompt(prompt)
                task.wait(0.5)
            end
        end
    end
    
    Configuration.Status = "[POTATO] Cutting potato..."
    local boards = lab:FindFirstChild("Cutting Boards")
    if boards then
        local cutter = boards:FindFirstChild("Potato Cutter")
        if cutter then
            local model = cutter:FindFirstChild("Model")
            if model then
                local union = model:FindFirstChild("Union")
                if union then
                    local att = union:FindFirstChild("Attachment")
                    if att then
                        local prompt = att:FindFirstChild("ProximityPrompt")
                        if prompt then
                            BikeTeleport(Locations.PotatoCutter)
                            task.wait(0.5)
                            local backpack = Player:FindFirstChild("Backpack")
                            if backpack then
                                local potato = backpack:FindFirstChild("Potato")
                                if potato then
                                    EquipTool(potato)
                                    task.wait(0.3)
                                    FirePrompt(prompt)
                                    task.wait(0.5)
                                    UnequipTools()
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    Configuration.Status = "[POTATO] Feeding homeless people..."
    if folders then
        local homelessList = folders:FindFirstChild("HomelessPeople")
        if homelessList then
            for _, homeless in pairs(homelessList:GetChildren()) do
                local backpack = Player:FindFirstChild("Backpack")
                if not backpack then break end
                local hotChips = backpack:FindFirstChild("Hot Chips")
                if not hotChips then break end
                
                local torso = homeless:FindFirstChild("UpperTorso")
                if torso then
                    local prompt = torso:FindFirstChild("ProximityPrompt")
                    if prompt then
                        BikeTeleport(torso.Position)
                        task.wait(0.5)
                        EquipTool(hotChips)
                        task.wait(0.3)
                        FirePrompt(prompt)
                        task.wait(0.5)
                        UnequipTools()
                        Configuration.ChipsFed = Configuration.ChipsFed + 1
                        task.wait(0.2)
                    end
                end
            end
        end
    end
    
    return true
end

-- ============================================
-- MAIN AUTOFARM LOOP
-- ============================================

local autofarmRunning = false

local function MainAutofarm()
    if autofarmRunning then return end
    autofarmRunning = true
    
    -- Spawn motor dulu
    Configuration.Status = "[START] Spawning bike..."
    if not SpawnAndSitOnBike() then
        Configuration.Status = "[ERROR] Failed to spawn bike!"
        autofarmRunning = false
        return
    end
    
    while Configuration.Autofarming do
        WaitForReady()
        
        local aptOk = StartMarshmallowFarm()
        if not aptOk then
            Configuration.Status = "[APT] Retrying in 5s..."
            task.wait(5)
            continue
        end
        
        PourWater()
        AddSugarAndGelatin()
        SellMarshmallow()
        
        MakePotatoChips()
        
        Configuration.Status = "[CYCLE] Complete! Restarting..."
        task.wait(3)
    end
    
    autofarmRunning = false
end

