-- FIRE PROMPT
-- ============================================

local function FirePrompt(prompt)
    if not prompt then return false end
    
    for i = 1, 3 do
        local success = false
        
        if fireproximityprompt then
            pcall(function()
                fireproximityprompt(prompt)
                success = true
            end)
        end
        
        if not success then
            pcall(function()
                prompt.HoldDuration = 0
                prompt.RequiresLineOfSight = false
                prompt.MaxActivationDistance = 100
                prompt:Fire()
                success = true
            end)
        end
        
        if success then return true end
        task.wait(0.3)
    end
    
    return false
end

-- ============================================
-- SPAWN & SIT ON BIKE (DIPERBAIKI)
-- ============================================

local function SpawnAndSitOnBike()
    local BikeName = string.format("%s's Car", Player.Name)
    local ExistingBike = Workspace:FindFirstChild(BikeName)
    
    -- Cek apakah sudah di motor
    if ExistingBike and ExistingBike:FindFirstChild("DriveSeat") then
        local seat = ExistingBike.DriveSeat
        if seat and seat.Occupant then
            Configuration.Status = "[BIKE] Already on bike!"
            Configuration.BikeSitting = true
            Configuration.BikeSpawned = true
            MotorBikeName = BikeName
            DriveSeat = seat
            Vehicle = ExistingBike
            return true
        end
    end
    
    Configuration.Status = "[BIKE] Spawning bike..."
    
    -- Spawn motor
    local Bike = Workspace:FindFirstChild(BikeName)
    if not Bike then
        RPC:FireServer(buffer.fromstring("\\001"), "Spawn", "DirtBike")
        local SpawnStart = os.clock()
        repeat 
            task.wait(0.5)
            Bike = Workspace:FindFirstChild(BikeName)
        until Bike or (os.clock() - SpawnStart) > 8
    end
    
    if not Bike then
        Configuration.Status = "[BIKE] Failed to spawn!"
        return false
    end
    
    local DriveSeat = Bike:FindFirstChild("DriveSeat")
    if not DriveSeat then
        Configuration.Status = "[BIKE] DriveSeat not found!"
        return false
    end
    
    Configuration.Status = "[BIKE] Teleporting to bike..."
    
    -- Teleport ke dekat motor
    local char = Player.Character
    if not char then return false end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local TargetCFrame = DriveSeat.CFrame * CFrame.new(3, 1, 0)
    
    for i = 1, 5 do
        pcall(function()
            hrp.CFrame = TargetCFrame
        end)
        task.wait(0.1)
    end
    
    task.wait(1)
    
    -- Cari prompt untuk naik
    local prompt = DriveSeat:FindFirstChild("ProximityPrompt")
    if not prompt then
        local att = DriveSeat:FindFirstChild("Attachment")
        if att then
            prompt = att:FindFirstChild("ProximityPrompt")
        end
    end
    
    if not prompt then
        Configuration.Status = "[BIKE] Prompt not found!"
        return false
    end
    
    Configuration.Status = "[BIKE] Sitting on bike..."
    prompt.HoldDuration = 0
    prompt.RequiresLineOfSight = false
    prompt.MaxActivationDistance = 50
    FirePrompt(prompt)
    
    task.wait(2)
    
    -- Cek apakah berhasil duduk
    if DriveSeat.Occupant then
        Configuration.Status = "[BIKE] Sitting on bike!"
        Configuration.BikeSitting = true
        Configuration.BikeSpawned = true
        MotorBikeName = BikeName
        DriveSeat = DriveSeat
        Vehicle = Bike
        return true
    end
    
    -- Coba lagi dengan metode lain
    for i = 1, 3 do
        pcall(function()
            hrp.CFrame = DriveSeat.CFrame * CFrame.new(0, 1, 0)
        end)
        task.wait(0.3)
        FirePrompt(prompt)
        task.wait(0.5)
        if DriveSeat.Occupant then
            Configuration.Status = "[BIKE] Sitting on bike!"
            Configuration.BikeSitting = true
            Configuration.BikeSpawned = true
            MotorBikeName = BikeName
            DriveSeat = DriveSeat
            Vehicle = Bike
            return true
        end
    end
    
    Configuration.Status = "[BIKE] Failed to sit!"
    return false
end

-- ============================================
-- BIKE TELEPORT (DENGAN MOTOR)
-- ============================================

local function BikeTeleport(TargetPosition)
    -- Cek apakah masih di motor
    local char = Player.Character
    if not char then return false end
    
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return false end
    
    -- Jika tidak di motor, coba duduk lagi
    if not hum.SeatPart then
        Configuration.Status = "[BIKE] Not on bike, re-sitting..."
        if not SpawnAndSitOnBike() then
            Configuration.Status = "[BIKE] Failed to re-sit!"
            return false
        end
        task.wait(0.5)
    end
    
    -- Cari DriveSeat
    local seat = hum.SeatPart
    if not seat or seat.Name ~= "DriveSeat" then
        Configuration.Status = "[BIKE] Not on DriveSeat!"
        return false
    end
    
    local vehicle = seat.Parent
    if not vehicle then return false end
    
    Configuration.Status = "[BIKE] Teleporting to " .. tostring(TargetPosition)
    
    -- Teleport motor ke posisi target
    pcall(function()
        vehicle:PivotTo(CFrame.new(TargetPosition))
    end)
    
    task.wait(0.3)
    
    -- Pastikan posisi
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        pcall(function()
            hrp.CFrame = CFrame.new(TargetPosition)
        end)
    end
    
    return true
end
