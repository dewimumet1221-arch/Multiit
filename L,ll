local function ClaimPotatoChipsAndSell()
    WaitForReady()
    Configuration.State["Status"] = "[POTATO] Waiting to cook..."
    DirtBikeTeleport(Locations.SafeZone)
    repeat task.wait(1) until PotTimer and PotTimer.Text == "0"

    Configuration.State["Status"] = "[POTATO] Claiming from pot..."
    repeat
        WaitForReady()
        DirtBikeTeleport(AvailablePot.Position)
        SmallDelay()
        fireproximityprompt(PotPrompt)
        task.wait(0.8)
    until Player:WaitForChild("Backpack"):FindFirstChild("Potato Chips")

    Configuration.State["Status"] = "[POTATO] Converting to hot chips..."
    repeat 
        WaitForReady() 
        DirtBikeTeleport(Locations.HotChipsMan) 
        SmallDelay()
    until Workspace:WaitForChild("Folders").NPCs:FindFirstChild("Poor Guy")

    local PoorGuy = Workspace:WaitForChild("Folders").NPCs:FindFirstChild("Poor Guy")
    local PoorGuyPrompt = PoorGuy.UpperTorso.ProximityPrompt
    repeat
        WaitForReady()
        DirtBikeTeleport(Locations.HotChipsMan)
        SmallDelay()
        fireproximityprompt(PoorGuyPrompt)
        UnequipTools()
        SmallDelay()
    until Player:WaitForChild("Backpack"):FindFirstChild("Hot Chips")

    BigDelay()

    -- FEED HOMELESS
    Configuration.State["Status"] = "[POTATO] Looking for homeless sitting..."

    local AvailableHomeless = {}
    local timeout = 45
    local startTime = os.clock()

    repeat
        AvailableHomeless = FindAvailableHomeless()
        if #AvailableHomeless > 0 then
            break
        end
        Configuration.State["Status"] = "[POTATO] Waiting for homeless to sit... (" .. math.floor(os.clock() - startTime) .. "s)"
        task.wait(3)
    until #AvailableHomeless > 0 or (os.clock() - startTime) > timeout

    if #AvailableHomeless == 0 then
        Configuration.State["Status"] = "[POTATO] No homeless sitting! Skipping..."
        return false
    end

    Configuration.State["Status"] = "[POTATO] Found " .. #AvailableHomeless .. " homeless sitting!"

    for _, HomelessRef in next, AvailableHomeless do
        if not Player:WaitForChild("Backpack"):FindFirstChild("Hot Chips") then break end
        
        local HomelessName = tostring(HomelessRef)
        repeat 
            WaitForReady() 
            DirtBikeTeleport(HomelessRef:FindFirstChild("UpperTorso").Position) 
            SmallDelay()
        until Workspace:WaitForChild("Folders").HomelessPeople:FindFirstChild(HomelessName)
        
        local Homeless = Workspace:WaitForChild("Folders").HomelessPeople:FindFirstChild(HomelessName)
        local UpperTorso = Homeless:FindFirstChild("UpperTorso")
        
        Configuration.State["Status"] = "[POTATO] Feeding " .. tostring(HomelessName)
        EquipTool(Player:WaitForChild("Backpack"):FindFirstChild("Hot Chips"))
        SmallDelay()
        fireproximityprompt(UpperTorso.ProximityPrompt)
