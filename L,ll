local Random = Random.new()

local function RandomDelay(min, max)
    local delay = Random:NextNumber(min, max)
    task.wait(delay)
end

local function SmallDelay()
    RandomDelay(0.3, 0.8)
end

local function MediumDelay()
    RandomDelay(1.0, 2.0)
end

local function BigDelay()
    RandomDelay(2.0, 4.0)
end

